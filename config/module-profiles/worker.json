{
  "module_type": "worker",
  "owners": ["worker-owner", "platform-owner"],
  "target_runtime_minutes": 10,
  "default_risk_tier": "high",
  "minimal_checks": [
    {"name": "validate", "command": "make validate"},
    {"name": "tooling-check", "command": "make tooling-check"}
  ],
  "escalation": {
    "risk_tiers": ["high", "critical"],
    "changed_file_patterns": ["tests/*", "scripts/*", "policies/*"],
    "checks": [
      {"name": "assurance-run", "command": "MODULE_TYPE=worker make run-assurance"}
    ]
  }
}
