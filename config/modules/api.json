{
  "moduleType": "api",
  "riskTier": "high",
  "mandatoryTests": [
    "lint",
    "unit",
    "integration",
    "contract",
    "backward-compat",
    "sast",
    "dependency-scan",
    "dast-smoke"
  ],
  "chaosRequiredScenarios": [
    "network_latency",
    "dependency_timeout",
    "queue_backlog"
  ],
  "promotionCriteria": {
    "stage": {
      "minPassRate": 0.97,
      "maxCriticalFindings": 0,
      "requiresSchemaCompatibility": true
    },
    "prod": {
      "minPassRate": 0.99,
      "maxCriticalFindings": 0,
      "maxHighFindings": 0,
      "requiresRollbackPlan": true,
      "requiresApprovalRoles": ["api-owner", "security-owner", "platform-owner"]
    }
  }
}
