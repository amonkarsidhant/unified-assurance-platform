      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NOT READY"
                },
                "1": {
                  "text": "READY"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 13,
      "title": "Onboarding Current Stage",
      "type": "table",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "onboarding_stage_current == 1",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        }
      ]
    },
    {
      "id": 14,
      "title": "Onboarding Plan Exists",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "onboarding_plan_exists",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "MISSING"
                },
                "1": {
                  "text": "EXISTS"
                }
              }
            }
          ]
        }
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 35
      },
      "id": 15,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "expr": "assurance_resilience_intelligence_status",
          "format": "table",
          "instant": true,
          "legendFormat": "status",
          "refId": "A"
        },
        {
          "expr": "assurance_resilience_intelligence_score",
          "format": "table",
          "instant": true,
          "legendFormat": "score",
          "refId": "B"
        }
      ],
      "title": "Resilience Intelligence (status/score)",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Value #A": 0,
              "Value #B": 1
            },
            "renameByName": {
              "Value #A": "status",
              "Value #B": "score"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "id": 16,
      "title": "Resilience Correlation (status/score/adapters)",
      "type": "table",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 35
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "assurance_resilience_correlation_status",
          "format": "table",
          "instant": true,
          "legendFormat": "correlation_status",
          "refId": "A"
        },
        {
          "expr": "assurance_resilience_correlation_score",
          "format": "table",
          "instant": true,
          "legendFormat": "correlation_score",
          "refId": "B"
        },
        {
          "expr": "assurance_resilience_adapter_count",
          "format": "table",
          "instant": true,
          "legendFormat": "adapter_count",
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value #A": "correlation_status",
              "Value #B": "correlation_score",
              "Value #C": "adapter_count"
            }
          }
        }
      ]
    }
