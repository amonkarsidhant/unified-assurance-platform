{
  "id": null,
  "uid": "uap-assurance-governance",
  "title": "UAP Assurance Governance Dashboard",
  "tags": [
    "uap",
    "assurance",
    "governance",
    "phase2.5"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": {
    "from": "now-24h",
    "to": "now"
