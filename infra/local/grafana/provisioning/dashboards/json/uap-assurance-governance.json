        {
          "expr": "assurance_evidence_fail_closed",
          "legendFormat": "fail_closed",
          "instant": true,
          "refId": "D"
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Failed Gates (list)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
