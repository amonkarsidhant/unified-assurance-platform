  "panels": [
    {
      "id": 1,
      "title": "Promotion Allowed",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "assurance_promotion_allowed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "BLOCKED"
                },
                "1": {
                  "text": "ALLOWED"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Failed Gates (count)",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "assurance_promotion_failed_gates_total",
          "refId": "A"
        }
      ]
    },
    {
