{
  "name": "unified-assurance-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Minimal scripts for local assurance smoke flow",
  "scripts": {
    "lint": "node scripts/lint-js.mjs",
    "test": "node --test tests/unit/**/*.test.mjs",
    "test:integration": "node --test tests/integration/**/*.test.mjs",
    "test:contract": "node --test tests/contract/**/*.test.mjs",
    "test:ui:smoke": "node scripts/ensure-playwright.mjs && npx playwright test tests/ui/smoke.spec.ts --config=playwright.config.ts --reporter=line",
    "typecheck": "tsc --noEmit",
    "coverage": "nyc --reporter=text --reporter=json node --test tests/unit/**/*.test.mjs",
    "coverage:report": "nyc report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "nyc": "^17.1.0",
    "typescript": "^5.9.3"
  }
}
