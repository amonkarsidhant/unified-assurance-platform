{
  "tier": "critical",
  "description": "Critical changes require all high controls plus resilience and mandatory chaos validation.",
  "mandatory_controls": [
    "sast",
    "sca",
    "secret_scan",
    "dast",
    "contract",
    "api_fuzz_contract",
    "dockerfile_policy",
    "iac_policy",
    "perf_smoke",
    "resilience",
    "chaos_resilience"
  ],
  "allowed_statuses": [
    "pass"
  ],
  "exception_allowed": false,
  "chaos_policy": {
    "required": true,
    "required_module_scenarios": {
      "api": [
        "network_latency",
        "dependency_timeout",
        "queue_backlog"
      ],
      "frontend": [
        "network_latency",
        "dependency_timeout",
        "process_kill"
      ],
      "worker": [
        "process_kill",
        "queue_backlog",
        "resource_stress"
      ],
      "shared-lib": [
        "dependency_timeout",
        "resource_stress",
        "process_kill"
      ]
    }
  }
}
